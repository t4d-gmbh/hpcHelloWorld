Bootstrap: docker
# Choose your image (debian with python3.13 here)
From: python:3.13-slim

%files
    # Copy your dependency files from the host into the container
    pyproject.toml /app/
    LICENSE /app/
    README.md /app/
    src /app/src
    scripts /app/scripts
    config /app/config
    # We could add data, especially for this toy-example
    # We add the .git just so we can fetch the git version during installation
    .git /app/.git
    # Uncomment the next line if you use a lockfile for exact reproducibility 
    # uv.lock /app/uv.lock 

%post 
    # System updates
    apt-get update && apt-get install -y curl git
    rm -rf /var/lib/apt/lists/*

    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/bin" sh

    # Move into the app directory 
    cd /app 


    # Create the virtual environment inside the container 
    export UV_LINK_MODE=copy
    export VIRTUAL_ENV=/opt/venv 
    export PATH="/opt/venv/bin:$PATH" 
    export UV_PROJECT_ENVIRONMENT="/opt/venv"
    export UV_LINK_MODE=copy

    # Create the python environment
    uv venv /opt/venv
 
    # Install dependencies directly from the pyproject.toml 
    uv pip install --no-cache --compile-bytecode .
    # replace with this if you pass uv.lock
    # uv sync --frozen --no-dev
 
    # (Optional) Clean up the .git/ (we only used it to fetch the version)
    rm -rf .git
    # (Optional) Clean up the cache to make the .sif file smaller 
    uv cache clean 

%environment
    # Ensure the container always uses this environment when running
    export VIRTUAL_ENV=/opt/venv
    # uv always prioritizes the local .venv, unless you force it not to:
    export UV_PROJECT_ENVIRONMENT="/opt/venv"
    # In case you use NixOS (wipe out the store):
    # export PATH="/opt/venv/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
    export PATH="/opt/venv/bin:$PATH"
    # Set the working directory directly to our project root inside the container
    export APPTAINER_PWD=/app
    export SINGULARITY_PWD=/app
    # Disable uv runtime filesystem modifications
    export UV_NO_SYNC=1
    export UV_FROZEN=1

# We force `exec` and `run` to change change working directory
%runscript
    cd /app
    exec "$@"


